#!/usr/bin/env bash
set -euo pipefail

# Get the latest Git tag
latest_tag=$(git tag --sort=committerdate | grep -E '^vscode-v[0-9]+\.[0-9]+\.[0-9]+$' | tail -1)
if [ -z "$latest_tag" ]; then
    echo "No tags found"
    exit 1
fi
echo "Latest tag: $latest_tag"
version=$(echo "$latest_tag" | sed 's/^vscode-v//')
echo "Latest version: $version"

# Ensure dist directory exists
mkdir -p dist

# Package VSIX only (no Marketplace/OpenVSX publish)
vsce package --no-git-tag-version --no-update-package-json --no-dependencies --skip-license -o "dist/shuvcode-${version}.vsix" "$version"

echo "VSIX packaged: dist/shuvcode-${version}.vsix"
